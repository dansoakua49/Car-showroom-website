<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Inventory | Imperial Motor House</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    /* PASTE ALL YOUR CSS TOKENS FROM INDEX HERE */
    :root { --bg: #0a0a0a; --surface: #131313; --border: #222222; --mid: #2a2a2a; --accent: #c0392b; --silver: #a8a8a8; --white: #f0eeeb; --font-display: 'Bebas Neue', sans-serif; --font-serif: 'Cormorant Garamond', serif; --font-body: 'Barlow', sans-serif; }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--white); font-family: var(--font-body); font-weight: 300; overflow-x: hidden; }
    a { color: inherit; text-decoration: none; }
    
    /* NAV & FOOTER STYLES (EXACTLY LIKE INDEX) */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 0 48px; height: 64px; background: rgba(10,10,10,0.92); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); }
    .nav-logo { font-family: var(--font-display); font-size: 22px; letter-spacing: .18em; color: var(--white); }
    .nav-logo span { color: var(--accent); }
    .nav-cta { font-family: var(--font-body); font-size: 11px; font-weight: 500; letter-spacing: .2em; text-transform: uppercase; padding: 9px 22px; border: 1px solid var(--silver); color: var(--silver); transition: all .25s; }
    .nav-cta:hover { border-color: var(--accent); color: var(--white); background: var(--accent); }

    /* INVENTORY SPECIFIC */
    .page-header { margin-top: 64px; padding: 80px 64px 40px; border-bottom: 1px solid var(--border); }
    .page-title { font-family: var(--font-display); font-size: clamp(40px, 6vw, 80px); letter-spacing: .05em; }
    .page-title span { color: var(--accent); }

    .filter-bar { display: flex; gap: 24px; padding: 24px 64px; background: var(--surface); border-bottom: 1px solid var(--border); overflow-x: auto; }
    .filter-btn { background: none; border: 1px solid var(--border); color: var(--silver); padding: 8px 18px; font-size: 11px; text-transform: uppercase; letter-spacing: .1em; cursor: pointer; transition: .3s; }
    .filter-btn.active, .filter-btn:hover { border-color: var(--accent); color: var(--white); }

    .car-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; padding: 40px 64px 80px; }
    .car-card { position: relative; overflow: hidden; aspect-ratio: 4/3; background: var(--surface); cursor: pointer; opacity: 0; transform: translateY(20px); transition: 0.6s all ease; }
    .car-card-img-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #1a1a1a, #050505); }
    .car-card-info { position: absolute; bottom: 0; left: 0; right: 0; padding: 20px 22px; background: linear-gradient(to top, rgba(0,0,0,0.9), transparent); }
    .car-card-name { font-family: var(--font-display); font-size: 22px; letter-spacing: .08em; }
    .car-card-price { font-family: var(--font-serif); font-size: 17px; font-style: italic; color: var(--accent); margin-top: 6px; }

    footer { border-top: 1px solid var(--border); background: #080808; padding: 60px 64px 36px; }
    .footer-brand-name { font-family: var(--font-display); font-size: 28px; letter-spacing: .14em; }
    .footer-brand-name span { color: var(--accent); }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">IMPERIAL<span>.</span>MOTOR</div>
    <a href="booking.html" class="nav-cta">Book a Viewing</a>
  </nav>

  <header class="page-header">
    <h1 class="page-title">Current <span>Inventory</span></h1>
    <p style="font-family: var(--font-serif); font-style: italic; color: var(--silver); margin-top: 10px;">A masterclass in automotive selection.</p>
  </header>

  <div class="filter-bar">
    <button class="filter-btn active">All Stock</button>
    <button class="filter-btn">Porsche</button>
    <button class="filter-btn">BMW M</button>
    <button class="filter-btn">Aston Martin</button>
    <button class="filter-btn">Electric</button>
  </div>

  <section class="car-grid" id="grid">
    <!-- Card 1 -->
    <div class="car-card" style="opacity: 1; transform: translateY(0);">
        <div class="car-card-img-placeholder">IMAGE</div>
        <div class="car-card-info">
          <div class="car-card-name">BMW M4 Competition</div>
          <div class="car-card-price">£86,500</div>
        </div>
    </div>
    <!-- Card 2 -->
    <div class="car-card" style="opacity: 1; transform: translateY(0);">
        <div class="car-card-img-placeholder">IMAGE</div>
        <div class="car-card-info">
          <div class="car-card-name">Porsche 911 Carrera</div>
          <div class="car-card-price">£112,000</div>
        </div>
    </div>
    <!-- Card 3 -->
    <div class="car-card" style="opacity: 1; transform: translateY(0);">
        <div class="car-card-img-placeholder">IMAGE</div>
        <div class="car-card-info">
          <div class="car-card-name">Aston Martin DBX</div>
          <div class="car-card-price">£194,000</div>
        </div>
    </div>
  </section>

  <footer>
    <div class="footer-brand-name">IMPERIAL<span>.</span>MOTOR</div>
    <p style="color: #444; font-size: 11px; margin-top: 20px;">© 2026 Imperial Motor House Ltd.</p>
  </footer>
</body>
</html>